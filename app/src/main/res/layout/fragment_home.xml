<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Menu Button -->

    <ImageButton
        android:id="@+id/menuButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:background="@android:color/transparent"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Greeting Section -->

    <LinearLayout
        android:id="@+id/greetingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/avatarView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🙂"
            android:textSize="34sp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/greetingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi"
            android:textSize="26sp"
            android:textStyle="bold"/>

    </LinearLayout>


    <!-- Subtitle -->

    <TextView
        android:id="@+id/subText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How are we feeling today?"
        android:textSize="16sp"
        android:textColor="#555555"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/greetingLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Write Journal -->

    <Button
        android:id="@+id/journalButton"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:text="Write Journal 📝"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_bg"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/subText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Track Mood -->

    <Button
        android:id="@+id/moodButton"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:text="Track Mood 📊"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_bg"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/journalButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Mood History -->

    <Button
        android:id="@+id/historyButton"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:text="Mood History 📈"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_bg"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/moodButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Journal History -->

    <Button
        android:id="@+id/journalHistoryButton"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:text="Journal History 📚"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_bg"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/historyButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>