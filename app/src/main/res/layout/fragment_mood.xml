<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:backgroundTint="#B0BEC5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track Your Mood Today 🌸"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your mood"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>


        <!-- Row 1 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/moodHappy"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😊 Happy"
                android:backgroundTint="#FFD54F"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodExcited"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🤩 Excited"
                android:backgroundTint="#F06292"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodNeutral"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😐 Neutral"
                android:backgroundTint="#FFB74D"
                android:layout_margin="6dp"/>

        </LinearLayout>


        <!-- Row 2 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/moodRelaxed"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😌 Relaxed"
                android:backgroundTint="#81C784"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodSad"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😔 Sad"
                android:backgroundTint="#64B5F6"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodAngry"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😡 Angry"
                android:backgroundTint="#E57373"
                android:layout_margin="6dp"/>

        </LinearLayout>


        <!-- Row 3 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/moodAnxious"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😟 Anxious"
                android:backgroundTint="#FFB74D"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodTired"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="😴 Tired"
                android:backgroundTint="#B0BEC5"
                android:layout_margin="6dp"/>

            <Button
                android:id="@+id/moodGrateful"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🥰 Grateful"
                android:backgroundTint="#BA68C8"
                android:layout_margin="6dp"/>

        </LinearLayout>


        <!-- Selected Mood Card -->

        <LinearLayout
            android:id="@+id/selectedMoodCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5E6F7"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/selectedMoodText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No mood selected"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/moodTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginTop="6dp"/>

        </LinearLayout>


        <!-- Tip Card -->

        <LinearLayout
            android:id="@+id/tipCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F8DDF1"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tipTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tip"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tipText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select a mood to see a tip"
                android:layout_marginTop="6dp"/>

        </LinearLayout>


        <!-- Recent Moods -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Moods"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:id="@+id/recentMoodLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/recent1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😊 Happy"
                android:layout_margin="6dp"/>

            <TextView
                android:id="@+id/recent2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😟 Anxious"
                android:layout_margin="6dp"/>

            <TextView
                android:id="@+id/recent3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤩 Excited"
                android:layout_margin="6dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>