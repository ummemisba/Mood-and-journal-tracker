<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back Button -->

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:backgroundTint="#B0BEC5"
            android:textColor="#FFFFFF" />

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mood History 📊"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:textColor="#333" />

        <!-- Mood Streak -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5E6F7"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Mood Streak"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/streakText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 days"
                android:layout_marginTop="6dp"/>
        </LinearLayout>


        <!-- Mood Statistics Chart -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F8DDF1"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Mood Statistics"
                android:textStyle="bold"
                android:textSize="25sp"/>


            <!-- Happy -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😊 Happy"/>

            <ProgressBar
                android:id="@+id/happyBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="50"
                android:progressTint="#FFD54F"
                android:layout_marginBottom="8dp"/>


            <!-- Neutral -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😐 Neutral"/>

            <ProgressBar
                android:id="@+id/neutralBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="30"
                android:progressTint="#FFB74D"
                android:layout_marginBottom="8dp"/>


            <!-- Sad -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😔 Sad"/>

            <ProgressBar
                android:id="@+id/sadBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="20"
                android:progressTint="#64B5F6"/>

        </LinearLayout>


        <!-- Mood Insight -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E6F2FF"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Mood Insight"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/insightText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You have been mostly happy this week!"
                android:layout_marginTop="6dp"/>
        </LinearLayout>


        <!-- Self Care Suggestion -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E8F8F5"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Self-Care Suggestion"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/adviceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Take a short break and hydrate today."
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>